# ==========================================
# CodeAlpha Custom IDS Rules Module
# ==========================================

# 1. Detect ICMP Ping Scans / Sweep Attempts
alert icmp any any -> $HOME_NET any (msg:"[ALERT] ICMP Ping Sweep/Scan Detected"; sid:1000001; rev:1;)

# 2. Detect Nmap TCP Syn Port Scan Attempts
alert tcp any any -> $HOME_NET any (flags:S; msg:"[ALERT] Potential TCP Port Scan Detected"; sid:1000002; rev:1;)

# 3. Detect Malicious Web Scanning (Directory Traversal Attempt)
alert tcp any any -> $HOME_NET 80 (msg:"[ALERT] Web Vulnerability Scan Attempt (../)"; content:"../"; nocase; sid:1000003; rev:1;)

# 4. Detect Unencrypted FTP Brute Force Attempts
alert tcp any any -> $HOME_NET 21 (msg:"[ALERT] FTP Authentication Brute Force Detected"; content:"530 Login incorrect"; nocase; sid:1000004; rev:1;)